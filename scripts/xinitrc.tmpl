#!/bin/sh
# X session for the calendar kiosk. Run by `startx` automatically on login.

# Disable screen blanking & power management
xset s off
xset -dpms
xset s noblank

# Hide mouse cursor after 1s of inactivity
unclutter -idle 1 -root &

# Tiny window manager so Chromium has someone to talk to about focus
openbox-session &

# Wait for backend to be reachable before opening Chromium
URL="http://localhost:8000/"
for _ in $(seq 1 60); do
  if curl -fsS --max-time 1 "$URL" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

# Wipe any "Chrome didn't shut down cleanly" prompt from a prior crash
PROFILE_DIR="${HOME}/.config/chromium"
PREFS="${PROFILE_DIR}/Default/Preferences"
if [ -f "$PREFS" ]; then
  sed -i 's/"exited_cleanly":false/"exited_cleanly":true/; s/"exit_type":"Crashed"/"exit_type":"Normal"/' "$PREFS" || true
fi

exec /usr/local/bin/calendar-kiosk-session "$URL"
